{
  "name": "@iimrd/dvbcss-protocols",
  "private": true,
  "description": "Javascript library implementing client and server code for DVB CSS sync protocols, based on the original library developed by the BBC.",
  "keywords": [
    "dvb",
    "dvbcss"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/IIMrd/dvbcss-protocols.git"
  },
  "directories": {
    "example": "examples"
  },
  "scripts": {
    "test": "vp test",
    "test:ui": "vp test --ui",
    "build": "vp run -r build",
    "check": "vp check",
    "clean": "rm -rf packages/*/dist && rm -rf packages/*/*.tsbuildinfo",
    "doc": "typedoc",
    "prepare": "vp config && vp run build && vp run doc"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/ws": "^8.18.1",
    "typedoc": "^0.28.5",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.5.2",
  "authors": [
    {
      "name": "British Broadcasting Corporation",
      "url": "http://www.bbc.co.uk/rd"
    },
    {
      "name": "Lluc Simó Margalef",
      "email": "lsimmar@teleco.upv.es"
    }
  ]
}
